{
  "name": "@cropwiseds/cropwise",
  "version": "1.0.2",
  "description": "Cropwise Components Library - React components from Figma",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./icons": {
      "import": "./dist/icons/index.mjs",
      "require": "./dist/icons/index.js",
      "types": "./dist/icons/index.d.ts"
    },
    "./icons/crop": {
      "import": "./dist/icons/crop/index.mjs",
      "require": "./dist/icons/crop/index.js",
      "types": "./dist/icons/crop/index.d.ts"
    },
    "./icons/design": {
      "import": "./dist/icons/design/index.mjs",
      "require": "./dist/icons/design/index.js",
      "types": "./dist/icons/design/index.d.ts"
    },
    "./icons/feature": {
      "import": "./dist/icons/feature/index.mjs",
      "require": "./dist/icons/feature/index.js",
      "types": "./dist/icons/feature/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.mjs",
      "require": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./theme/theme.css": "./dist/theme/theme.css",
    "./theme/fonts.css": "./dist/theme/fonts.css",
    "./theme.css": "./dist/theme/theme.css",
    "./fonts.css": "./dist/theme/fonts.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/icons/index.ts src/icons/crop/index.ts src/icons/design/index.ts src/icons/feature/index.ts src/components/index.ts --format esm,cjs --dts && node -e \"require('fs').mkdirSync('dist/theme',{recursive:true}); ['theme.css','fonts.css'].forEach(f=>require('fs').copyFileSync('src/theme/'+f,'dist/theme/'+f))\"",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.18",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vite": "^8.0.1"
  },
  "license": "UNLICENSED",
  "sideEffects": [
    "**/*.css"
  ],
  "dependencies": {
    "@figma/code-connect": "^1.4.1",
    "all": "^0.0.0"
  }
}
