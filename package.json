{
  "name": "@icons-library/cropwise",
  "version": "1.0.0",
  "description": "Cropwise Icons Library - React SVG icon components from Figma",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./crop": {
      "import": "./dist/crop/index.mjs",
      "require": "./dist/crop/index.js",
      "types": "./dist/crop/index.d.ts"
    },
    "./design": {
      "import": "./dist/design/index.mjs",
      "require": "./dist/design/index.js",
      "types": "./dist/design/index.d.ts"
    },
    "./feature": {
      "import": "./dist/feature/index.mjs",
      "require": "./dist/feature/index.js",
      "types": "./dist/feature/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/crop/index.ts src/design/index.ts src/feature/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "license": "UNLICENSED",
  "sideEffects": false,
  "dependencies": {
    "@figma/code-connect": "^1.4.1"
  }
}
